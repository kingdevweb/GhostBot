# GhostBot — Variables d'environnement
# Kopye fichye sa a → .env  epi ranpli valè yo

# ── Bot Identity ─────────────────────────────────────────
BOT_NAME=GhostBot
OWNER_NAME=King Fixed
OWNER_NUMBER=50955394345       # Nimewo WhatsApp ou (san +)
PREFIX=.

# ── AI APIs ──────────────────────────────────────────────
GEMINI_API_KEY=                # https://aistudio.google.com/apikey
OPENAI_API_KEY=                # https://platform.openai.com/api-keys  (opsyonèl)
AI_PROVIDER=gemini             # "gemini" | "openai"

# ── Other APIs ───────────────────────────────────────────
REMOVEBG_API_KEY=              # https://remove.bg/api
OPENWEATHER_API_KEY=           # https://openweathermap.org/api
OCR_API_KEY=                   # https://ocr.space/ocrapi

# ── Server ───────────────────────────────────────────────
PORT=3000                      # Render ap mete sa otomatikman
TIMEZONE=America/Port-au-Prince

# ── Persistence (Render sèlman) ───────────────────────────
# SESSION_DIR=/opt/render/project/src/data/session
# DB_DIR=/opt/render/project/src/data/database
